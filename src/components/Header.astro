---
import { profile } from "@/data/profile";
import LanguageSwitch from "./LanguageSwitch.astro";
---

<header class="site-header">
  <a class="brand mono" href="/" aria-label="Home">
    <span>{profile.initials}</span>
    <small data-i18n="personalLab">PERSONAL LAB</small>
  </a>
  <div class="right">
    <nav class="mono" aria-label="Primary navigation">
      <a href="/projects" data-i18n="navWorks">Works</a>
      <a href="/resume" data-i18n="navResume">Resume</a>
      <a href="/blog" data-i18n="navLogs">Logs</a>
      <a href="/changelog" data-i18n="navUpdates">Updates</a>
      <a href="#contact" data-i18n="navContact">Contact</a>
    </nav>
    <LanguageSwitch />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: min(100% - 32px, 1320px);
    margin: 0 auto;
    padding: 18px 0;
    border-bottom: 1px solid rgba(244, 244, 240, 0.18);
    background: rgba(5, 5, 5, 0.58);
    backdrop-filter: blur(16px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-weight: 900;
    letter-spacing: 0.16em;
  }

  .brand span {
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border: 1px solid var(--text);
    border-radius: 999px;
    color: var(--accent);
  }

  .brand small {
    color: var(--muted);
    font-size: 11px;
  }

  nav {
    display: flex;
    gap: 30px;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  nav a {
    color: var(--muted);
  }

  nav a:hover {
    color: var(--text);
  }

  @media (max-width: 760px) {
    .brand small {
      display: none;
    }

    nav {
      gap: 14px;
      font-size: 10px;
    }

    .right {
      gap: 10px;
    }
  }

  @media (max-width: 560px) {
    nav a:nth-child(3),
    nav a:nth-child(4),
    nav a:nth-child(5) {
      display: none;
    }
  }
</style>
