---
import { projects } from "@/data/profile";
import SectionHeader from "./SectionHeader.astro";
---

<section class="section" id="works">
  <div class="container">
    <SectionHeader
      index="01"
      kicker="Selected Works"
      title="Projects as case records, not thumbnail noise."
      kickerKey="worksKicker"
      titleKey="worksTitle"
    />
    <div class="projects">
      {
        projects.map((project) => (
          <a class="project cut-card" href={project.href}>
            <span class="mono id">{project.id}</span>
            <div>
              <h3>{project.title}</h3>
              <p data-i18n={`project${project.id.replace(/^0/, "")}Summary`}>{project.summary}</p>
              <ul class="mono">
                {project.stack.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
            <strong class="mono" data-i18n="open">OPEN -></strong>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects {
    display: grid;
    gap: 16px;
  }

  .project {
    --cut-size: 18px;
    display: grid;
    grid-template-columns: 88px 1fr auto;
    gap: 24px;
    align-items: start;
    padding: 28px;
    overflow: hidden;
    clip-path: polygon(
      0 0,
      calc(100% - var(--cut-size)) 0,
      100% var(--cut-size),
      100% 100%,
      var(--cut-size) 100%,
      0 calc(100% - var(--cut-size))
    );
    transition:
      border-color 180ms ease,
      transform 180ms ease,
      background 180ms ease,
      clip-path 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project:hover {
    transform: translateX(8px);
    border-color: var(--accent);
    background: rgba(215, 255, 63, 0.045);
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
  }

  .project::before,
  .project::after {
    z-index: 1;
    width: 0;
    height: 0;
    background: transparent;
    opacity: 0;
    transition:
      width 320ms cubic-bezier(0.22, 1, 0.36, 1),
      height 320ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 160ms ease;
  }

  .project::before {
    top: 0;
    right: 0;
    border-top: 1px solid var(--accent);
    border-right: 1px solid var(--accent);
  }

  .project::after {
    bottom: 0;
    left: 0;
    border-bottom: 1px solid var(--accent);
    border-left: 1px solid var(--accent);
  }

  .project:hover::before,
  .project:hover::after {
    width: 54px;
    height: 54px;
    opacity: 1;
  }

  .id {
    color: var(--accent);
    font-size: 28px;
    font-weight: 900;
  }

  h3 {
    margin: 0;
    font-size: clamp(26px, 3.4vw, 52px);
    letter-spacing: -0.05em;
    line-height: 0.98;
    text-transform: uppercase;
  }

  p {
    max-width: 760px;
    margin: 16px 0 0;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.6;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0;
    margin: 18px 0 0;
    list-style: none;
  }

  li {
    padding: 6px 9px;
    border: 1px solid var(--line);
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  strong {
    color: var(--muted);
    font-size: 12px;
    letter-spacing: 0.12em;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .project {
      grid-template-columns: 1fr;
    }
  }
</style>
