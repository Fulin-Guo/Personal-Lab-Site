---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.published.getTime() - a.data.published.getTime(),
);

const toSlug = (id: string) => id.replace(/\.(md|mdx)$/, "");
---

<BaseLayout title="Technical Logs | Personal Lab">
  <Header />
  <main class="container page">
    <p class="mono eyebrow" data-i18n="pageBlogKicker">TECHNICAL LOGS</p>
    <h1 data-i18n="pageBlogTitle">Writing index.</h1>
    <div class="logs">
      {
        posts.map((post, index) => (
          <a class="log-row" href={`/blog/${toSlug(post.id)}/`}>
            <span class="mono">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <ul class="mono">
                {post.data.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            </div>
            <time class="mono" datetime={post.data.published.toISOString()}>
              {post.data.published.toISOString().slice(0, 10)}
            </time>
          </a>
        ))
      }
    </div>
  </main>
</BaseLayout>

<style>
  .page {
    padding: 86px 0;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.18em;
  }

  h1 {
    margin: 0 0 48px;
    font-size: clamp(58px, 12vw, 160px);
    letter-spacing: -0.08em;
    line-height: 0.86;
    text-transform: uppercase;
  }

  .logs {
    border-top: 1px solid var(--line);
  }

  .log-row {
    display: grid;
    grid-template-columns: 70px 1fr 140px;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
  }

  .log-row:hover h2 {
    color: var(--accent);
  }

  .log-row > span,
  time {
    color: var(--muted);
    font-size: 12px;
    letter-spacing: 0.14em;
  }

  h2 {
    margin: 0;
    font-size: clamp(28px, 4vw, 58px);
    letter-spacing: -0.06em;
    line-height: 0.95;
    text-transform: uppercase;
  }

  p {
    color: var(--muted);
    line-height: 1.6;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0;
    list-style: none;
  }

  li {
    padding: 5px 8px;
    border: 1px solid var(--line);
    color: var(--muted);
    font-size: 11px;
    text-transform: uppercase;
  }

  @media (max-width: 760px) {
    .log-row {
      grid-template-columns: 1fr;
    }
  }
</style>
