---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Personal Lab`} description={post.data.description}>
  <Header />
  <main class="container article">
    <a class="mono back" href="/blog" data-i18n="backToLogs">← Back to logs</a>
    <p class="mono eyebrow">{post.data.published.toISOString().slice(0, 10)} / {post.data.tags.join(" / ")}</p>
    <h1>{post.data.title}</h1>
    <p class="description">{post.data.description}</p>
    <article class="content">
      <Content />
    </article>
  </main>
</BaseLayout>

<style>
  .article {
    max-width: 860px;
    padding: 86px 0 120px;
  }

  .back,
  .eyebrow {
    color: var(--accent);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .back {
    display: inline-block;
    margin-bottom: 44px;
  }

  h1 {
    margin: 0;
    font-size: clamp(48px, 8vw, 112px);
    letter-spacing: -0.075em;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .description {
    margin: 24px 0 48px;
    color: var(--muted);
    font-size: 22px;
    line-height: 1.6;
  }

  .content {
    border-top: 1px solid var(--line);
    padding-top: 34px;
    color: #deded8;
    font-size: 18px;
    line-height: 1.8;
  }

  .content :global(h2) {
    margin-top: 42px;
    font-size: 34px;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  .content :global(p),
  .content :global(li) {
    color: var(--muted);
  }

  .content :global(code) {
    padding: 2px 5px;
    background: var(--panel-2);
    color: var(--accent);
  }

  .content :global(pre) {
    overflow-x: auto;
    padding: 18px;
    border: 1px solid var(--line);
    background: #090909;
  }
</style>
